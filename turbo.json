{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "dependsOn": [
        "test:unit",
        "test:integration"
      ]
    },
    "test:unit": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tests/**",
        "*.test.*"
      ]
    },
    "test:integration": {
      "dependsOn": [
        "test:unit"
      ],
      "inputs": [
        "src/**",
        "tests/**"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "e2e/**",
        "src/**"
      ]
    }
  }
}